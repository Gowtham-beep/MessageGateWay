# Gateway API port
PORT=3000
# Mock provider API port
PROVIDER_PORT=4000
# Nexus API auth token
NEXUS_TOKEN=mock_nexus
# Orbit API auth key
ORBIT_API_KEY=mock_orbit
# Secret to sign webhooks
NEXUS_WEBHOOK_SECRET=mock_secret
# SQLite database path
DB_PATH=./data.sqlite
# URL for webhooks
GATEWAY_URL=http://localhost:3000
# URL for outbound sends
PROVIDER_BASE_URL=http://localhost:4000
# Sleep duration for simulated timeouts
MOCK_TIMEOUT_MS=5000
# Gateway outbound request timeout
NEXUS_TIMEOUT_MS=2000
# Webhook timestamp tolerance
WEBHOOK_TOLERANCE_SEC=300
# Poller interval (0 = off)
POLL_INTERVAL_MS=0
# Wait limit for concurrent dispatches
DISPATCH_WAIT_MS=2000
